# =============================================================================
# BIM Builders — required environment variables
# Copy this file to `.env` and fill in real values. Never commit .env.
# =============================================================================

# ── Groq (AI assistant; required by /api/chat) ──────────────────────────────
# Get from https://console.groq.com/keys
GROQ_API_KEY=

# ── EmailJS (contact form; required by /api/contact) ────────────────────────
# Service / template IDs and the PUBLIC key are safe in the client bundle.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_USER_TEMPLATE_ID=

# Required when "Use Private Key" is enabled in EmailJS Security settings.
# Server-only. Do NOT prefix with NEXT_PUBLIC_.
EMAILJS_PRIVATE_KEY=
