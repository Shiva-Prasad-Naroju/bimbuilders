# Chat (BIM Assistant)
GROQ_API_KEY=

# Contact form — EmailJS (server-side via /api/contact)
# Public IDs can use NEXT_PUBLIC_* (already in your project) or server-only EMAILJS_* names.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_ADMIN_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_USER_TEMPLATE_ID=

# Required for server-side sends (EmailJS Account → API keys → Private Key)
# Never expose this with NEXT_PUBLIC_
EMAILJS_PRIVATE_KEY=

# Optional server-only aliases (override NEXT_PUBLIC_* when set)
# EMAILJS_SERVICE_ID=
# EMAILJS_PUBLIC_KEY=
# EMAILJS_ADMIN_TEMPLATE_ID=
# EMAILJS_USER_TEMPLATE_ID=

# EmailJS dashboard: Account → Security
# - Enable "Allow EmailJS API for non-browser applications"
# - If "Use Private Key" is on, EMAILJS_PRIVATE_KEY must be set

# Optional — not used by contact form
# RESEND_API_KEY=
